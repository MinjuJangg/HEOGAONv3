# Copy this file to .env at the project root.
# Keep real keys out of git.

# Frontend
NEXT_PUBLIC_HEOGAON_API_BASE_URL=http://127.0.0.1:4100
NEXT_PUBLIC_KAKAO_JS_KEY=
NEXT_PUBLIC_DATA_GO_KR_SERVICE_KEY=

# Backend / GMS
LLM_API_KEY=
LLM_MODEL=gpt-5.5
LLM_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
GMS_API_KEY=
GMS_MODEL=gpt-5.5
GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
HEOGAON_SLOT_PROVIDER=
HEOGAON_JUDGEMENT_PROVIDER=
HEOGAON_INQUIRY_PROVIDER=

# Public APIs
JUSO_API_KEY=
DATA_GO_KR_SERVICE_KEY=
KAKAO_REST_API_KEY=

# Local data
SEOUL_LOCALDATA_INDEX=

# Admin (관리자 패널 비밀번호 — 비워두면 관리자 API 접근이 차단됨)
ADMIN_PASSWORD=

# Runtime
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3103,http://localhost:3103
